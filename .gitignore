local_device_prefs.json
gcg_settings.json
grades_*.json
grading_cache.json
workspace_startup.log
pdf_cache/
thumb_cache/

# ---------------------------------------------------------------------------
# Real student data  (NEVER commit — this repo ships fictional sample data only)
# ---------------------------------------------------------------------------
# The tracked acm_database.json is invented sample data (see tools/
# generate_sample_data.py). Real gradebooks/rosters live OUTSIDE the repo in the
# folder pointed to by local_device_prefs.json -> db_custom_path. These patterns
# stop any real export that lands in the working tree from being committed:
*Grades*.csv
*grades*.csv
*roster*.csv
*Roster*.csv
acm_database.json.bak-*
acm_term_summaries_*.json
*.docx
*.pdf
